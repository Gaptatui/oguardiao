rules_version = '2';

// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: alertas
// Document ID: auto-generated
// Fields:
//   - tipo: string (Médica, Segurança, Acidente, Desconhecido)
//   - gravidade: string (Baixa, Média, Alta, Crítica)
//   - transcricao: string
//   - sons_fundo: string
//   - analise_ia_audio: string
//   - prioridade: string
//   - timestamp: number
//   - uid: string (owner)
//   - status: string (Pendente, Em Atendimento, Resolvido)
//
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "gersonproenca@gmail.com" && request.auth.token.email_verified == true);
    }

    function isPro() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.plan == 'pro';
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'plan']) &&
             data.uid is string &&
             data.email is string &&
             data.plan in ['free', 'pro'] &&
             (!('subscriptionStatus' in data) || data.subscriptionStatus in ['active', 'inactive', 'past_due']) &&
             (!('subscriptionPeriod' in data) || data.subscriptionPeriod in ['monthly', 'yearly']) &&
             (!('nextBillingDate' in data) || data.nextBillingDate == null || data.nextBillingDate is number) &&
             (!('paymentMethod' in data) || data.paymentMethod is string);
    }

    function isValidAlerta(data) {
      return data.keys().hasAll(['tipo', 'gravidade', 'timestamp', 'uid']) &&
             data.tipo is string &&
             data.gravidade is string &&
             data.timestamp is number &&
             data.uid is string &&
             data.uid == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{uid} {
      allow read: if isAuthenticated() && (isOwner(uid) || isAdmin());
      allow create: if isOwner(uid) && isValidUser(request.resource.data) && 
                      request.resource.data.isAdmin == false &&
                      request.resource.data.isVip == false &&
                      request.resource.data.plan == 'free';
      
      // Em produção, campos de assinatura (plan, status, nextBillingDate) 
      // devem ser atualizados apenas via Backend/Webhooks do provedor de pagamento.
      // Aqui permitimos que o Admin gerencie tudo e o Usuário altere apenas dados básicos.
      allow update: if isAuthenticated() && (
                      isAdmin() || 
                      (isOwner(uid) && isValidUser(request.resource.data) && 
                       request.resource.data.isAdmin == resource.data.isAdmin &&
                       request.resource.data.isVip == resource.data.isVip &&
                       (request.resource.data.plan == resource.data.plan || request.resource.data.plan == 'pro'))
                    );
    }

    match /configuracoes_usuario/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    match /alertas/{alertaId} {
      allow create: if isAuthenticated() && isValidAlerta(request.resource.data);
      allow read: if isDocOwner() || isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /vizinhos_alertas/{alertaId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow delete: if isDocOwner() || isAdmin();
    }

    match /perfis_saude/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid);
    }

    match /lembretes_medicacao/{lembreteId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    match /mercado_talentos/{servicoId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }
  }
}
