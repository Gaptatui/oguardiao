{
  "entities": {
    "Alerta": {
      "title": "Alerta de Emergência",
      "description": "Um alerta de emergência gerado por áudio.",
      "type": "object",
      "properties": {
        "tipo": { "type": "string" },
        "gravidade": { "type": "string" },
        "transcricao": { "type": "string" },
        "sons_fundo": { "type": "string" },
        "analise_ia_audio": { "type": "string" },
        "prioridade": { "type": "string" },
        "timestamp": { "type": "number" },
        "uid": { "type": "string" },
        "status": { "type": "string" },
        "userEmail": { "type": "string" }
      },
      "required": ["tipo", "gravidade", "timestamp", "uid"]
    },
    "VizinhoAlerta": {
      "title": "Alerta da Rede de Vizinhos",
      "description": "Relatos da comunidade sobre segurança local.",
      "type": "object",
      "properties": {
        "titulo": { "type": "string" },
        "descricao": { "type": "string" },
        "categoria": { "type": "string" },
        "timestamp": { "type": "number" },
        "uid": { "type": "string" },
        "userName": { "type": "string" }
      },
      "required": ["titulo", "descricao", "timestamp", "uid"]
    },
    "PerfilSaude": {
      "title": "Perfil de Saúde Universal",
      "description": "Dados médicos para emergências.",
      "type": "object",
      "properties": {
        "tipoSanguineo": { "type": "string" },
        "alergias": { "type": "string" },
        "historico": { "type": "string" },
        "medicacoes": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["uid"]
    },
    "LembreteMedicao": {
      "title": "Lembrete de Medicação",
      "description": "Lembretes de remédios para o usuário.",
      "type": "object",
      "properties": {
        "nome": { "type": "string" },
        "horario": { "type": "string" },
        "dosagem": { "type": "string" },
        "uid": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["nome", "horario", "uid"]
    },
    "ServicoTalento": {
      "title": "Serviço no Mercado de Talentos",
      "description": "Oferta de serviço técnico ou consultoria.",
      "type": "object",
      "properties": {
        "titulo": { "type": "string" },
        "descricao": { "type": "string" },
        "categoria": { "type": "string" },
        "preco": { "type": "string" },
        "uid": { "type": "string" },
        "userName": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["titulo", "descricao", "uid"]
    },
    "User": {
      "title": "Perfil do Usuário",
      "description": "Informações do perfil do usuário, incluindo detalhes da assinatura.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "plan": { "type": "string", "enum": ["free", "pro"] },
        "subscriptionStatus": { "type": "string", "enum": ["active", "inactive", "past_due"] },
        "subscriptionPeriod": { "type": "string", "enum": ["monthly", "yearly"] },
        "nextBillingDate": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "isVip": { "type": "boolean" },
        "timestamp": { "type": "number" }
      },
      "required": ["uid", "email", "plan"]
    },
    "ConfiguracoesUsuario": {
      "title": "Configurações do Usuário",
      "description": "Preferências de idioma e dados pessoais do usuário.",
      "type": "object",
      "properties": {
        "language": { "type": "string" },
        "personalData": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string" },
            "phone": { "type": "string" }
          }
        },
        "updatedAt": { "type": "number" }
      }
    },
    "TransacaoFinanceira": {
      "title": "Transação Financeira",
      "description": "Registro de pagamentos e assinaturas.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "userEmail": { "type": "string" },
        "valor": { "type": "number" },
        "moeda": { "type": "string" },
        "tipo": { "type": "string", "enum": ["assinatura_mensal", "assinatura_anual"] },
        "status": { "type": "string", "enum": ["concluido", "pendente", "falhou"] },
        "timestamp": { "type": "number" }
      },
      "required": ["uid", "valor", "tipo", "status", "timestamp"]
    },
    "UsoModulo": {
      "title": "Uso de Módulo",
      "description": "Log de utilização de funcionalidades do app.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "modulo": { "type": "string", "enum": ["golpes", "emergencia", "rota_segura", "saude", "talentos"] },
        "timestamp": { "type": "number" }
      },
      "required": ["modulo", "timestamp"]
    },
    "ContatoEmergencia": {
      "title": "Contato de Emergência",
      "description": "Contatos para notificação em caso de emergência.",
      "type": "object",
      "properties": {
        "nome": { "type": "string" },
        "parentesco": { "type": "string" },
        "telefone": { "type": "string" },
        "active": { "type": "boolean" },
        "deleted": { "type": "boolean" },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "uid": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["nome", "telefone", "uid"]
    }
  },
  "firestore": {
    "users/{uid}": {
      "schema": "User",
      "description": "Perfis dos usuários e configurações de conta."
    },
    "configuracoes_usuario/{uid}": {
      "schema": "ConfiguracoesUsuario",
      "description": "Preferências e dados pessoais do usuário."
    },
    "alertas/{alertaId}": {
      "schema": "Alerta",
      "description": "Coleção de alertas de emergência."
    },
    "vizinhos_alertas/{alertaId}": {
      "schema": "VizinhoAlerta",
      "description": "Feed da rede de vizinhos."
    },
    "perfis_saude/{uid}": {
      "schema": "PerfilSaude",
      "description": "Perfis de saúde dos usuários."
    },
    "lembretes_medicacao/{lembreteId}": {
      "schema": "LembreteMedicao",
      "description": "Lembretes de remédios."
    },
    "mercado_talentos/{servicoId}": {
      "schema": "ServicoTalento",
      "description": "Serviços oferecidos na comunidade."
    },
    "transacoes/{transacaoId}": {
      "schema": "TransacaoFinanceira",
      "description": "Histórico de pagamentos do aplicativo."
    },
    "logs_uso/{logId}": {
      "schema": "UsoModulo",
      "description": "Logs de utilização para análise de métricas."
    },
    "contatos_emergencia/{contatoId}": {
      "schema": "ContatoEmergencia",
      "description": "Contatos de emergência do usuário."
    }
  }
}
